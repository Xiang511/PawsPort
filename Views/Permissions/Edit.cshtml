@model PawsPort.ViewModels.PermissionEditViewModel

@{
    ViewData["Title"] = "編輯權限";
}

<h1>編輯權限</h1>

<div class="card shadow mb-4" style="box-shadow: 0 .15rem 0 0 rgba(58, 59, 69, .15) !important;">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">編輯使用者系統角色</h6>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="MappingId" />
            <input type="hidden" asp-for="UserId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label class="control-label">
                    <i class="fas fa-user"></i> 使用者
                </label>
                <input type="text" value="@Model.UserName (ID: @Model.UserId)" class="form-control" readonly />
                <small class="form-text text-muted">使用者資訊無法更改</small>
            </div>

            <div class="form-group">
                <label for="SystemId" class="control-label">
                    <i class="fas fa-cogs"></i> 系統
                </label>
                <select id="SystemId" name="SystemId" class="form-control" required>
                    @foreach (var system in Model.Systems)
                    {
                        <option value="@system.SystemId" selected="@(Model.SystemId == system.SystemId ? "selected" : null)">
                            @system.SystemName
                        </option>
                    }
                </select>
                <small class="form-text text-muted">
                    目前選擇：<span class="badge badge-info">@Model.Systems.FirstOrDefault(s => s.SystemId == Model.SystemId)?.SystemName</span>
                </small>
            </div>

            <div class="form-group">
                <label for="RoleId" class="control-label">
                    <i class="fas fa-user-tag"></i> 角色
                </label>
                <select id="RoleId" name="RoleId" class="form-control" required>
                    @foreach (var role in Model.Roles)
                    {
                        <option value="@role.RoleId" selected="@(Model.RoleId == role.RoleId ? "selected" : null)">
                            @role.RoleName
                        </option>
                    }
                </select>
                <small class="form-text text-muted">
                    目前選擇：<span class="badge badge-info">@Model.Roles.FirstOrDefault(r => r.RoleId == Model.RoleId)?.RoleName</span>
                </small>
            </div>

            <div class="form-group">
                <small class="form-text text-muted">
                    <i class="fas fa-clock"></i> 最後更新時間：@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "無")
                </small>
            </div>

            <hr />

            <div class="form-group mb-0">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> 更新
                </button>
                <a asp-action="List" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> 返回列表
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // 表單驗證提示
        $('form').on('submit', function(e) {
            var systemId = $('#SystemId').val();
            var roleId = $('#RoleId').val();

            if (!systemId || !roleId) {
                e.preventDefault();
                alert('請選擇系統和角色！');
                return false;
            }
        });
    </script>
}
