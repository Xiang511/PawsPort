@model IEnumerable<PawsPort.ViewModels.HealthPassportListViewModel>

@{
    ViewData["Title"] = "List";
}

<h1>寵物健康護照</h1>
@using (Html.BeginForm())
{
    @:關鍵字 @Html.TextBox("txtKeyword")
    <input type="submit" value="查詢" />
}

<p>
    <a asp-action="Create" class="btn btn-primary ">新增資料</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.PassportId)</th>
            <th>@Html.DisplayNameFor(model => model.PetId)</th>

            <th>@Html.DisplayNameFor(model => model.Name)</th>

            <th>@Html.DisplayNameFor(model => model.Weight)</th>
            <th>@Html.DisplayNameFor(model => model.Note)</th>
            <th>@Html.DisplayNameFor(model => model.RecordType)</th>
            <th>@Html.DisplayNameFor(model => model.RecordDate)</th>
            <th>@Html.DisplayNameFor(model => model.UpdatedAt)</th>
            <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.PassportId)</td>
                <td>@Html.DisplayFor(modelItem => item.PetId)</td>

                <td>@Html.DisplayFor(modelItem => item.Name)</td>

                <td>@Html.DisplayFor(modelItem => item.Weight)</td>
                <td>@Html.DisplayFor(modelItem => item.Note)</td>
                <td>@Html.DisplayFor(modelItem => item.RecordType)</td>
                <td>@Html.DisplayFor(modelItem => item.RecordDate)</td>
                <td>@Html.DisplayFor(modelItem => item.UpdatedAt)</td>
                <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                <td>
                    @Html.ActionLink("編輯", "Edit", "PassPort", new { id = item.PassportId }, new { @class = "btn btn-success" }) |
                    @Html.ActionLink("Details", "Details", "PassPort", new { id = item.PassportId }, new { @class = "btn btn-primary" }) |
                    
                    @Html.ActionLink("刪除", "Delete", "PassPort", new { id = item.PassportId }, new { onclick = "return confirm('確定要刪除嗎?')", Class = "btn btn-danger" }) 
                </td>
            </tr>
        }
        
    </tbody>
</table>

@if (TempData["ErrorMessage"] != null)
{
    <script>
        // 加入 Html.Raw() 讓系統輸出原本的中文字！
        alert('@Html.Raw(TempData["ErrorMessage"])');
    </script>
}