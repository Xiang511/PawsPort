@model PawsPort.ViewModels.ArticleListViewModel

@{
    ViewData["Title"] = "貼文內容管理";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-newspaper mr-2"></i>貼文內容管理</h1>
        @* 這裡通常不從後端新增文章，所以放個匯出或統計按鈕 *@
        <button class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-download fa-sm text-white-50"></i> 產生文章報表
        </button>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">總文章數量</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalCount 篇</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-file-alt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" action="@Url.Action("ArticleList")" id="filterForm">
                <div class="row align-items-center">
                    <div class="col-md-8 d-flex align-items-center">
                        <div class="input-group" style="width: 300px;">
                            <input type="text" name="TxtKeyword" value="@Model.TxtKeyword"
                                   class="form-control bg-light border-0 small" placeholder="搜尋標題、內容或作者...">
                            <div class="input-group-append">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fas fa-search fa-sm"></i>
                                </button>
                            </div>
                        </div>

                        <div class="ml-4 d-flex align-items-center">
                            <span class="text-xs mr-2">顯示</span>
                            <select name="PageSize" class="form-control form-control-sm" onchange="this.form.submit()" style="width: 80px;">
                                <option value="10" selected="@(Model.PageSize == 10)">10 筆</option>
                                <option value="20" selected="@(Model.PageSize == 20)">20 筆</option>
                                <option value="50" selected="@(Model.PageSize == 50)">50 筆</option>
                            </select>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.TxtKeyword))
                        {
                            <a href="@Url.Action("ArticleList")" class="ml-3 btn btn-link btn-sm text-secondary">清除條件</a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">文章清單</h6>
            @* 右側按鈕：新增貼文 *@
            <a asp-action="CreateArticle" class="btn btn-success btn-sm shadow-sm">
                <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> 新增貼文
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                    <thead class="thead-light text-center">
                        <tr>
                            <th width="80">ID</th>
                            <th>標題</th>
                            <th width="120">作者</th>
                            <th width="120">分類</th>
                            <th width="100">數據統計</th>
                            <th width="160">發布時間</th>
                            <th width="120">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ArticleItem != null && Model.ArticleItem.Any())
                        {
                            foreach (var item in Model.ArticleItem)
                            {
                                <tr>
                                    <td class="text-center align-middle">@item.ArticleId</td>
                                    <td class="align-middle">
                                        <div class="font-weight-bold text-dark text-truncate" style="max-width: 250px;">
                                            @item.Title
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge badge-light p-2"><i class="fas fa-user mr-1"></i>@item.AuthorName</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge badge-info">@item.CategoryName</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="small text-muted">
                                            <i class="fas fa-eye fa-fw"></i> @item.ViewCount <br />
                                            <i class="fas fa-comment fa-fw"></i> @item.CommentCount <br />
                                            <i class="fas fa-bookmark fa-fw"></i> @item.BookmarkCount
                                        </div>
                                    </td>
                                    <td class="text-center align-middle small">
                                        @item.CreateAt.ToString("yyyy-MM-dd")<br />
                                        @item.CreateAt.ToString("HH:mm")
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="btn-group">
                                            @* 預留跳轉至前台查看的按鈕 *@
                                            <a href="#" class="btn btn-sm btn-outline-primary" title="查看文章">
                                                <i class="fas fa-external-link-alt"></i>
                                            </a>
                                            <a asp-action="EditArticle" asp-route-id="@item.ArticleId" class="btn btn-sm btn-outline-info" title="編輯">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="DeleteArticle" asp-route-id="@item.ArticleId" class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('確定要刪除這篇文章嗎？');" title="刪除">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">目前沒有符合條件的文章</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="row mt-3">
                    <div class="col-sm-12 col-md-5">
                        <div class="text-sm text-gray-600">
                            顯示第 @(((Model.CurrentPage - 1) * Model.PageSize) + 1) 到 @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) 筆，共 @Model.TotalCount 筆
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-7">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-end mb-0">
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("ArticleList", new { CurrentPage = Model.CurrentPage - 1, TxtKeyword = Model.TxtKeyword, PageSize = Model.PageSize })">上一頁</a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("ArticleList", new { CurrentPage = i, TxtKeyword = Model.TxtKeyword, PageSize = Model.PageSize })">@i</a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("ArticleList", new { CurrentPage = Model.CurrentPage + 1, TxtKeyword = Model.TxtKeyword, PageSize = Model.PageSize })">下一頁</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        </div>
    </div>
</div>