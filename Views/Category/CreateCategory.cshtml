@model PawsPort.Models.Category

@{
    ViewData["Title"] = "新增分類";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-plus-circle mr-2"></i>新增分類項目</h1>
        <a asp-action="CategoryList" class="btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm"></i> 返回列表
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-bottom-primary">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">分類詳細資訊設定</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateCategory" method="post">
                        @* 安全性驗證標記 *@
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CategoryName" class="font-weight-bold text-dark">分類名稱</label>
                                    <input asp-for="CategoryName" class="form-control" placeholder="例如：狗狗鮮食" required />
                                    @* 顯示 ViewModel/Model 的驗證錯誤訊息 *@
                                    <span asp-validation-for="CategoryName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ParentId" class="font-weight-bold text-dark">所屬上級 (大分類)</label>
                                    <select asp-for="ParentId" class="form-control">
                                        <option value="">-- 無 (設為第一層大分類) --</option>
                                        @if (ViewBag.ParentList != null)
                                        {
                                            foreach (var item in (List<PawsPort.Models.Category>)ViewBag.ParentList)
                                            {
                                                <option value="@item.CategoryId">@item.CategoryName</option>
                                            }
                                        }
                                    </select>
                                    <small class="form-text text-muted">若不選擇，此項目將成為獨立的大分類。</small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mt-3">
                            <label asp-for="CategoryDescription" class="font-weight-bold text-dark">分類描述</label>
                            <textarea asp-for="CategoryDescription" class="form-control" rows="3" placeholder="請輸入對此分類的簡易描述..."></textarea>
                            <span asp-validation-for="CategoryDescription" class="text-danger small"></span>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SortOrder" class="font-weight-bold text-dark">排序序號</label>
                                    <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                                    <small class="form-text text-muted">數字越小，在後台列表顯示越前面。</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="alert alert-info small mt-4">
                                    <i class="fas fa-info-circle mr-1"></i>
                                    <strong>小提醒：</strong><br />
                                    系統會自動判斷：若有選父類，則自動存為「子分類」；若沒選，則存為「主分類」。
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="text-right">
                            <button type="reset" class="btn btn-light mr-2">重填內容</button>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="fas fa-save mr-1"></i> 確認新增分類
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* 啟用用戶端驗證，讓網頁不必重整就能顯示部分錯誤訊息 *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}