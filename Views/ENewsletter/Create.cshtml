@model PawsPort.Models.ENewsletter

@{
    ViewData["Title"] = "新增電子報";
}

<h2 class="font-weight-bold">．發布新電子報</h2>
<h6 class="text-muted mb-4">※請填寫以下資訊來建立新的電子報</h6>


<form action="~/ENewsletter/Create" method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="font-weight-bold text-primary"><i class="fas fa-edit mr-2"></i>電子報內容</h5>
                </div>
                <small class="text-danger ml-2">* 必填 *</small>
                <div class="card-body">                    
                    <div class="form-group">
                        <label class="font-weight-bold">．電子報標題<span class="text-danger ml-2">*</span></label>
                        <input type="text" name="Title" class="form-control" placeholder="請輸入吸引人的標題..." required />
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．前導摘要<span class="text-danger ml-2">*</span></label>
                        <textarea name="Summary" class="form-control" rows="2" placeholder="列表上顯示的簡短說明（建議50字以內）" required></textarea>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．完整內文<span class="text-danger ml-2">*</span></label>
                        <textarea name="Content" class="form-control" rows="12" placeholder="請在這裡輸入電子報的完整內容..." required></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="font-weight-bold text-info"><i class="fas fa-cog mr-2"></i>發佈設定</h5>
                </div>
                <div class="card-body">
                    
                    <div class="form-group">
                        <label class="font-weight-bold">．文章分類<span class="text-danger ml-2">*</span></label>
                        <select name="Category" class="form-control">
                            <option value="活動公告">活動公告</option>
                            <option value="認養資訊">認養資訊</option>                            
                            <option value="飼養知識">飼養知識</option>
                            <option value="遊戲挑戰">遊戲挑戰</option>
                            <option value="其它分類">其它分類</option>
                        </select>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．發佈狀態<span class="text-danger ml-2">*</span></label>
                        <select name="Status" class="form-control">
                            <option value="草稿">草稿（暫不公開）</option>
                            <option value="已發送">立即發送</option>
                            <option value="預約發送">預約發送</option>
                        </select>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．預約/發佈日期<span class="text-danger ml-2">*</span></label>
                        <input type="datetime-local" name="PublishDate" class="form-control" />
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．內部備註<span class="text-danger ml-2">*</span></label>
                        <textarea name="Note" class="form-control" rows="3" placeholder="僅供內部管理員查看..."></textarea>
                    </div>

                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="~/ENewsletter/List" class="btn btn-outline-secondary font-weight-bold px-4">
                    <i class="fas fa-arrow-left mr-2"></i>取消建立並返回
                </a>
                <button type="submit" class="btn btn-warning text-dark font-weight-bold px-4 shadow-sm">
                    <i class="bi bi-floppy2 mr-2"></i>確認建立
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
