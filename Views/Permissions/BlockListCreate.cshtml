@model IEnumerable<PawsPort.ViewModels.BlockListViewModel>
@{
    ViewData["Title"] = "BlockListCreate";
}
<link href="~/css/XiangBtn.css" rel="stylesheet" />
<h1>封鎖使用者</h1>

<div class="card shadow mb-4" style="box-shadow: 0 .15rem 0 0 rgba(58, 59, 69, .15) !important;">
    <div class="card-body">
        <form asp-action="BlockListCreate" method="post">
            <div class="form-group">
                <label for="UserId" class="control-label">選擇使用者</label>
                <select id="UserId" name="UserId" class="form-control" required>
                    <option value="" disabled selected>-- 請選擇使用者 --</option>
                    @foreach (var user in Model)
                    {
                        <option value="@user.UserId">@user.Name (ID: @user.UserId)</option>
                    }
                </select>
            </div>
            <div class="d-flex">
                <span class="d-inline-block mt-3 mr-3">使用者狀態</span>
                <div class="checkbox-wrapper-55">
                    <label for="Status" class="rocker rocker-small">
                        <input type="checkbox" id="Status" name="Status" checked />
                        <span class="switch-left" for="Status">啟用</span>
                        <span class="switch-right" for="Status">封鎖</span>
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label for="Note" class="control-label">封鎖原因</label>
                <textarea id="Note" name="Note" class="form-control" rows="3" required></textarea>
            </div>
         
            <input type="submit" value="儲存" class="btn btn-primary" />
            <a asp-action="BlockList" class="btn btn-secondary">返回列表</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}