@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "玩家管理";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="m-0">玩家管理</h1>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="ListDatatable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th style="width: 10%;text-align:center">玩家ID</th>
                        <th style="width: 10%;text-align:center">點數</th>
                        <th style="width: 10%;text-align:center">持有造型數量</th>
                        <th style="width: 10%;text-align:center">遊玩進度</th>
                        <th style="width: 20%;text-align:center">最後遊玩時間</th>
                        <th style="width: 20%;text-align:center">動作</th>
                        <th style="width: 10%;text-align:center">會員</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align:center;vertical-align:middle">
                                @item.PlayerId
                            </td>
                            <td style="text-align:center;vertical-align:middle">@item.Point</td>
                            <td style="text-align:center;vertical-align:middle">@item.SkinCount</td>
                            <td style="text-align:center;vertical-align:middle">@(item.MaxGameId > 0 ? "第 " + item.MaxGameId + " 關" : "未開始")</td>
                            <td style="text-align:center;vertical-align:middle">@(item.LastPlayedDate != null ? item.LastPlayedDate.ToString("yyyy-MM-dd HH:mm") : "未遊玩")</td>
                            <td style="white-space: nowrap;text-align:center;vertical-align:middle">
                                <button type="button" class="btn btn-sm btn-warning edit-btn"
                                        data-id="@item.PlayerId"
                                        data-toggle="modal"
                                        data-target="#EditBn">
                                    <i class="fa-solid fa-pen-to-square"></i> 編輯
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deletePlayer(@item.PlayerId)">
                                    <i class="fa-solid fa-trash"></i> 刪除
                                </button>
                                <button type="button" class="btn btn-sm btn-info"
                                        data-toggle="modal"
                                        data-target="#ViewLogsBn_@item.PlayerId">
                                    <i class="fa-solid fa-receipt"></i> 消費紀錄
                                </button>
                                <button type="button" class="btn btn-sm btn-success"
                                        data-toggle="modal"
                                        data-target="#ViewPointRecordsBn_@item.PlayerId">
                                    <i class="fa-solid fa-coins"></i> 點數紀錄
                                </button>
                                
                            </td>
                            <td style="text-align:center">
                                <a href="~/Member/List">
                                <button type="button" class="btn btn-sm">
                                    <i class="fa-solid fa-user"></i> 查看會員檔案
                                </button>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- 分頁導航 -->
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    <!-- 上一頁按鈕 -->
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Player/List?page=@(ViewBag.CurrentPage - 1)">
                                <i class="fa-solid fa-chevron-left"></i> 上一頁
                            </a>

                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">
                                <i class="fa-solid fa-chevron-left"></i> 上一頁
                            </span>
                        </li>
                    }

                    <!-- 頁碼按鈕 -->
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        @if (i == ViewBag.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("List", "Players", new { page = i })">@i</a>
                            </li>
                        }
                    }

                    <!-- 下一頁按鈕 -->
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Player/List?page=@(ViewBag.CurrentPage + 1)">
                                下一頁 <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">
                                下一頁 <i class="fa-solid fa-chevron-right"></i>
                            </span>
                        </li>
                    }
                </ul>
                <div class="text-center text-muted mt-2">
                    <small>第 @ViewBag.CurrentPage 頁，共 @ViewBag.TotalPages 頁（總計 @ViewBag.TotalCount 筆玩家）</small>
                </div>
            </nav>

        </div>
    </div>
</div>

<!-- 編輯 Modal -->
<div class="modal fade" id="EditBn" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" style="margin-left: auto; margin-right: auto;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">編輯玩家<span id="EditPlayerIdDisplay"></span></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form method="post" asp-action="Edit" asp-controller="Player">
                <div class="modal-body">
                    <input type="hidden" id="EditPlayerId" name="PlayerId" />

                    <!-- 玩家點數 -->
                    <div class="form-group">
                        <label for="EditPoint">點數</label>
                        <input type="number" class="form-control" id="EditPoint" name="Point" placeholder="輸入點數" min="0" required />
                    </div>

                    <!-- 遊玩進度 -->
                    <div class="form-group">
                        <label>遊玩進度</label>
                        <input type="text" class="form-control" id="EditGameProgress" readonly />
                    </div>

                    <!-- 最後遊玩時間 -->
                    <div class="form-group">
                        <label>最後遊玩時間</label>
                        <input type="text" class="form-control" id="EditLastPlayedDate" readonly />
                    </div>

                    <!-- 持有造型 -->
                    <div class="form-group">
                        <label>持有造型</label>
                        <div id="SkinsList" style="border: 1px solid #ddd; padding: 10px; border-radius: 4px; max-height: 300px; overflow-y: auto;">
                            <!-- 造型列表將由 JavaScript 動態生成 -->
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="EditSubmitBtn">保存變更</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">取消</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- 刪除確認 Modal -->
<div class="modal fade" id="DeleteBn" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">確認刪除</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>確定要刪除玩家「<span id="DeletePlayerId"></span>」嗎？</p>
                <p style="color: red;">此操作無法撤銷！</p>
            </div>
            <div class="modal-footer">
                <form method="post" asp-action="Delete" asp-controller="Player" style="display: inline;">
                    <input type="hidden" id="DeletePlayerIdInput" name="id" />
                    <button type="submit" class="btn btn-danger">確認刪除</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">取消</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 為每個玩家生成一個消費紀錄 Modal -->
@foreach (var player in Model)
{
    <div class="modal fade" id="ViewLogsBn_@player.PlayerId" tabindex="-1" aria-labelledby="viewLogsModalLabel_@player.PlayerId" aria-hidden="true">
        <div class="modal-dialog modal-lg" style="margin-left: auto; margin-right: auto;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="viewLogsModalLabel_@player.PlayerId">玩家 @player.PlayerId 的消費紀錄</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th style="width: 15%;">造型ID</th>
                                <th style="width: 25%;">消費時間</th>
                                <th style="width: 20%;">金額</th>
                                <th style="width: 20%;">剩餘點數</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (player.InventoryLogs == null || player.InventoryLogs.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" style="text-align: center; color: #999;">該玩家沒有消費紀錄</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var log in player.InventoryLogs)
                                {
                                    <tr>
                                        <td style="text-align:center">@log.SkinId</td>
                                        <td>@log.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@log.Price</td>
                                        <td>@log.Point</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">關閉</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 點數來源紀錄 Modal -->
@foreach (var player in Model)
{
    <div class="modal fade" id="ViewPointRecordsBn_@player.PlayerId" tabindex="-1" aria-labelledby="viewPointRecordsModalLabel_@player.PlayerId" aria-hidden="true">
        <div class="modal-dialog modal-lg" style="margin-left: auto; margin-right: auto;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="viewPointRecordsModalLabel_@player.PlayerId">玩家 @player.PlayerId 的點數來源紀錄</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th style="width: 25%;">創建時間</th>
                                <th style="width: 35%;">來源</th>
                                <th style="width: 20%;">點數</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (player.PointRecords == null || player.PointRecords.Count == 0)
                            {
                                <tr>
                                    <td colspan="3" style="text-align: center; color: #999;">該玩家沒有點數紀錄</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var record in player.PointRecords)
                                {
                                    <tr>
                                        <td>@record.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            @if (record.GameId > 0)
                                            {
                                                <span>遊戲 第 @record.GameId 關</span>
                                            }
                                            else
                                            {
                                                <span>@record.Upstream</span>
                                            }
                                        </td>
                                        <td>@record.Point</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">關閉</button>
                </div>
            </div>
        </div>
    </div>
}




<script>
    // 編輯按鈕點擊事件
    document.addEventListener('click', function(e) {
        if (e.target.closest('.edit-btn')) {
            const btn = e.target.closest('.edit-btn');
            const playerId = btn.dataset.id;
            
            // 獲取玩家詳細信息
            fetch(`/Player/GetPlayerDetails?playerId=${playerId}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('EditPlayerIdDisplay').textContent = data.playerId;
                    document.getElementById('EditPlayerId').value = data.playerId;
                    document.getElementById('EditPoint').value = data.point;
                    document.getElementById('EditGameProgress').value = data.maxGameId > 0 ? `第 ${data.maxGameId} 關` : '未開始';
                    document.getElementById('EditLastPlayedDate').value = data.lastPlayedDate;
                    
                    // 生成造型列表
                    const skinsList = document.getElementById('SkinsList');
                    skinsList.innerHTML = '';
                    
                    if (data.skins.length === 0) {
                        skinsList.innerHTML = '<p style="margin: 0; color: #999;">該玩家沒有持有任何造型</p>';
                    } else {
                            data.skins.forEach(skin => {
        const skinItem = document.createElement('div');
        skinItem.style.cssText = 'display: flex; justify-content: space-between; align-items: center; padding: 8px; border-bottom: 1px solid #eee;';
        skinItem.innerHTML = `
            <div style="display: flex; align-items: center; gap: 10px;">
                ${skin.skinImage ? `<img src="${skin.skinImage}" alt="${skin.skinName}" style="width: 50px; height: 50px; border: 1px solid #ddd; border-radius: 4px; object-fit: cover;" />` : '<span style="width: 50px; height: 50px; background-color: #f0f0f0; border: 1px solid #ddd; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #999;">無圖片</span>'}
                <div>
                    <div><strong>${skin.skinName}</strong></div>
                    <div style="font-size: 12px; color: #666;">造型 ID: ${skin.skinId}</div>
                </div>
            </div>
            <div class="custom-control custom-checkbox">
                <input type="checkbox" class="custom-control-input skin-checkbox" name="EnabledSkinIds" value="${skin.inventoryId}" id="skin_${skin.inventoryId}" ${skin.enable ? 'checked' : ''} />
                <label class="custom-control-label" for="skin_${skin.inventoryId}">
                    啟用
                </label>
            </div>
        `;
        skinsList.appendChild(skinItem);
    });
                    }
                })
                .catch(error => console.error('Error:', error));
        }
    });

    function deletePlayer(playerId) {
        document.getElementById('DeletePlayerId').textContent = playerId;
        document.getElementById('DeletePlayerIdInput').value = playerId;
        $('#DeleteBn').modal('show');
    }
</script>
