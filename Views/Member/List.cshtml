@model IEnumerable<PawsPort.Models.UserTable>

@{
    ViewData["Title"] = "List";
}
<link href="~/css/XiangList.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<h1>Member</h1>
<span>會員管理 <i class="fa-solid fa-angle-right"></i> <span class="text-primary">基本資料維護</span></span>

<div class="row mt-3">

    <!-- Earnings (Monthly) Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            會員總數
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.MemberCount</div>
                    </div>
                    <div class="col-auto">
            
                        <i class="fas fa-solid fa-users text-gray-300 fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Earnings (Annual) Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            當月註冊人數
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.MemberMonthSignUp</div>
                    </div>
                    <div class="col-auto">
                        <i class=" fas fa-solid fa-user-plus text-gray-300 fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tasks Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            帳號認證比例
                        </div>
                        <div class="row no-gutters align-items-center">
                            <div class="col-auto">
                                <div class="h5 mb-0 mr-3 font-weight-bold text-gray-800">@ViewBag.Verify %</div>
                            </div>
                            <div class="col">
                                <div class="progress progress-sm mr-2">
                                    <div class="progress-bar bg-info" role="progressbar"
                                         style="width: @ViewBag.Verify%" aria-valuenow="50" aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-solid fa-envelope-circle-check text-gray-300 fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Requests Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            活躍訂閱數
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.MemberRss</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-solid fa-rss text-gray-300 fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card shadow mb-4">
    <div class="card-body">
        <div class="w-100 d-flex justify-content-end">
            <a asp-action="Create" class="btn btn-light btn-icon-split">
                <span class="icon text-gray-600">
                    <i class="fa-solid fa-plus"></i>
                </span>
                <span class="text">新增會員</span>
            </a>
        </div>
      
        
        <div class="table-responsive">
            <table class="table table-bordered" id="ListDatatable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.UserId)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Job)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Phone)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.City)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Point)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Note)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.HasPriorExp)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Status)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.IsSubscribe)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.IsVerify)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.CreatedAt)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.UpdatedAt)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.UserId)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Job)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Phone)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.City)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Point)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Note)
                            </td>
                            @if (item.HasPriorExp == true)
                            {
                                <td>是</td>
                            }
                            else
                            {
                                <td>否</td>
                            }
                           
                            @if (item.Status == true)
                            {
                                <td><span class="badge badge-pill badge-primary">正常</span></td>
                            }
                            else
                            {
                                <td><span class="badge badge-pill badge-danger">Ban</span></td>
                            }
             
                         
                                
                            @if (item.IsSubscribe == true)
                            {
                                <td>是</td>
                            }
                            else
                            {
                                <td>否</td>
                            }

                            @if (item.IsVerify == true)
                            {
                                <td>是</td>
                            }
                            else
                            {
                                <td>否</td>
                            }
                            <td>
                                @(item.CreatedAt?.ToString("yyyy/MM/dd") ?? "無日期")
                            </td>
                            <td>
                                @(item.UpdatedAt?.ToString("yyyy/MM/dd") ?? "無日期")
                            </td>
                            <td>
                                @Html.ActionLink("編輯", "Edit", new { id = item.UserId }) |
                               
                                @Html.ActionLink("刪除", "Delete", new { id = item.UserId }, new { onclick = "return confirm('您確定要刪除此使用者嗎？');", @class = "" })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/demo/MemberListDataTable.js"></script>