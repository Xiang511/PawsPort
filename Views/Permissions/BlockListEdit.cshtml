@model PawsPort.ViewModels.BlockListViewModel
@{
    ViewData["Title"] = "BlockListEdit";
}
<link href="~/css/XiangBtn.css" rel="stylesheet" />
<h1>編輯封鎖狀態</h1>
<span class="d-block my-3">會員管理 <i class="fa-solid fa-angle-right"></i> <span class="text-primary">違規名單</span> <i class="fa-solid fa-angle-right"></i> <span class="text-primary">編輯</span></span>
<div class="card shadow mb-4" style="box-shadow: 0 .15rem 0 0 rgba(58, 59, 69, .15) !important;">
    <div class="card-body">
        <form asp-action="BlockListEdit" method="post">
            <input type="hidden" asp-for="UserId" />

            <div class="form-group">
                <label class="control-label">使用者 ID</label>
                <input type="text" value="@Model.UserId" class="form-control" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Name" class="control-label">使用者名稱</label>
                <input asp-for="Name" class="form-control" readonly />
            </div>

            <div class="d-flex">
                <span class="d-inline-block mt-3 mr-3">使用者狀態</span>
                <div class="checkbox-wrapper-55">
                    <label for="Status" class="rocker rocker-small">
                        <input type="checkbox" id="Status" name="Status" asp-for="Status" />
                        <span class="switch-left" for="Status">啟用</span>
                        <span class="switch-right" for="Status">封鎖</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Note" class="control-label">封鎖原因 / 備註</label>
                <textarea asp-for="Note" class="form-control" rows="3" required></textarea>
            </div>

            <input type="submit" value="儲存" class="btn btn-primary" />
            <a asp-action="BlockList" class="btn btn-secondary">返回列表</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}