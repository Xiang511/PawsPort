@model PawsPort.Models.ENewsletter

@{
    ViewData["Title"] = "修改電子報";

    
    string datepick = "";
        
    if (Model.PublishDate.HasValue == true)
    {
        // 3. 如果有值，就把日期拿出來，格式化之後存進變數裡
        datepick = Model.PublishDate.Value.ToString("yyyy-MM-dd HH:mm");
    }
}


<style>
   
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">" !important;
        color: #6c757d;
    }
</style>

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
    <ol class="breadcrumb bg-transparent px-0 mb-2">
        <li class="breadcrumb-item"><a href="~/Home/Index" class="text-decoration-none text-muted"><i class="fas fa-home mr-1"></i>首頁</a></li>

        <li class="breadcrumb-item"><a href="~/enewsletter/List" class="text-decoration-none text-muted">電子報管理專區</a></li>
                
        <li class="breadcrumb-item active font-weight-bold" aria-current="page" style="color: #8C5A3C; !important;">修改電子報</li>
    </ol>
</nav>




<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">


<h2 class="font-weight-bold">．修改電子報</h2>
<h6 class="text-muted mb-4">※請編輯以下資訊以修改電子報內容</h6>

    
<form action="~/ENewsletter/Edit" method="post">
    <input type="hidden" name="NewsLetterId" value="@Model.NewsLetterId" />
    
    <input type="hidden" name="UserId" value="@Model.UserId" />

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="font-weight-bold" style="color: #8C5A3C;">
                        <i class="fas fa-edit mr-2"></i>電子報內容
                    </h5>
                </div>
                <small class="text-danger ml-2">* 必填 *</small>
                <div class="card-body">
                    <div class="form-group">
                        <label class="font-weight-bold">．電子報標題<span class="text-danger ml-2">*</span></label>
                        <input type="text" name="Title" class="form-control" value="@Model.Title" required />
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．前導摘要<span class="text-danger ml-2">*</span></label>
                        <textarea name="Summary" class="form-control" rows="2" required>@Model.Summary</textarea>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．完整內文<span class="text-danger ml-2">*</span></label>
                        <textarea name="Content" class="form-control" rows="12" required>@Model.Content</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="font-weight-bold" style="color: #8C5A3C;"><i class="fas fa-cog mr-2"></i>發佈設定</h5>
                </div>
                <div class="card-body">
                    
                    <div class="form-group">
                        <label class="font-weight-bold">．文章分類<span class="text-danger ml-2">*</span></label>
                        <select name="Category" class="form-control">
                            <option value="活動公告" selected=@(Model.Category == "活動公告" ? "selected" : "")>活動公告</option>
                            <option value="認養資訊" selected=@(Model.Category == "認養資訊" ? "selected" : "")>認養資訊</option>
                            <option value="飼養知識" selected=@(Model.Category == "飼養知識" ? "selected" : "")>飼養知識</option>
                            <option value="遊戲挑戰" selected=@(Model.Category == "遊戲挑戰" ? "selected" : "")>遊戲挑戰</option>
                            <option value="其它類別" selected=@(Model.Category == "其它類別" ? "selected" : "")>其它類別</option>
                        </select>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．發佈狀態<span class="text-danger ml-2">*</span></label>
                        <select name="Status" class="form-control">
                            <option value="草稿" selected=@(Model.Status == "草稿" ? "selected" : "")>草稿（暫不公開）</option>
                            <option value="已發送" selected=@(Model.Status == "已發送" ? "selected" : "")>立即發送</option>
                            <option value="預約發送" selected=@(Model.Status == "預約發送" ? "selected" : "")>預約發送</option>
                            <option value="已下架" selected=@(Model.Status == "已下架" ? "selected" : "")>已下架</option>
                        </select>
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．預約/發佈日期</label>
                        <input type="text" id="publishdatepicker" name="PublishDate" class="form-control bg-white" value="@datepick" />
                    </div>

                    <div class="form-group mt-3">
                        <label class="font-weight-bold">．內部備註</label>
                        <textarea name="Note" class="form-control" rows="3">@Model.Note</textarea>
                    </div>

                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="~/ENewsletter/List" class="btn btn-outline-secondary font-weight-bold px-4">
                    <i class="fas fa-arrow-left mr-2"></i>取消並返回
                </a>
                <button type="submit" class="btn btn-info font-weight-bold px-4 shadow-sm">
                    <i class="bi bi-floppy2 mr-2"></i>儲存修改
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        flatpickr("#publishdatepicker", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        time_24hr: true
        });
        });
    </script>
}
