@model PawsPort.Models.Category

@{
    ViewData["Title"] = "編輯分類";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-edit mr-2"></i>編輯分類內容</h1>
        <a asp-action="CategoryList" class="btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm"></i> 返回列表
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-bottom-info">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">修改分類：@Model.CategoryName</h6>
                </div>
                <div class="card-body">
                    <form asp-action="EditCategory" method="post">
                        @Html.AntiForgeryToken()
                        
                        @* 必須包含隱藏欄位，否則後端不知道要改哪一筆 *@
                        <input type="hidden" asp-for="CategoryId" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CategoryName" class="font-weight-bold text-dark">分類名稱</label>
                                    <input asp-for="CategoryName" class="form-control" required />
                                    <span asp-validation-for="CategoryName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="ParentId" class="font-weight-bold text-dark">所屬上級 (大分類)</label>
                                    <select name="ParentId" class="form-control">
                                        <option value="">-- 無 (設為第一層大分類) --</option>
                                        @if (ViewBag.ParentList != null)
                                        {
                                            foreach (var item in (List<PawsPort.Models.Category>)ViewBag.ParentList)
                                            {
                                                // 使用 string 比對避免型別問題，確保 selected 屬性生效
                                                bool isSelected = (item.CategoryId == Model.ParentId);
                                                if (isSelected)
                                                {
                                                    <option value="@item.CategoryId" selected="selected">@item.CategoryName</option>
                                                }
                                                else
                                                {
                                                    <option value="@item.CategoryId">@item.CategoryName</option>
                                                }
                                            }
                                        }
                                    </select>
                                    <small class="form-text text-muted">
                                        當前：@(Model.Level == 0 ? "主分類" : "子分類")
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mt-3">
                            <label asp-for="CategoryDescription" class="font-weight-bold text-dark">分類描述</label>
                            <textarea asp-for="CategoryDescription" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SortOrder" class="font-weight-bold text-dark">排序序號</label>
                                    <input asp-for="SortOrder" type="number" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted mt-4">
                                    建立時間：@Model.CreateAt.ToString("yyyy-MM-dd HH:mm") <br />
                                    最後修改：@Model.LastEditTime?.ToString("yyyy-MM-dd HH:mm")
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="text-right">
                            <button type="submit" class="btn btn-info px-5 shadow-sm">
                                <i class="fas fa-check-circle mr-1"></i> 儲存修改
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}